# These are the same variables as the root .env.example. The server loads its
# environment from the root .env file, this copy exists for reference when
# working inside server/ directly (e.g. configuring the Render service).

# OpenAI API key. Leave blank to run in demo mode with deterministic mock ad copy.
OPENAI_API_KEY=

# OpenAI text model used to generate ad copy.
AI_TEXT_MODEL=gpt-4o-mini

# OpenAI image model used to generate the creative image.
AI_IMAGE_MODEL=gpt-image-1

# PostgreSQL connection string (e.g. from Neon).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Port the Express server listens on. Render sets this automatically.
PORT=5000

# Allowed frontend origin for CORS. Leave blank locally to allow http://localhost:5173
# and any *.vercel.app preview URL. Set to your deployed Vercel URL in production.
CORS_ORIGIN=
